MONGODB_CONNECTION_STRING=...
MONGODB_DATABASE=agent_memory
MONGODB_COLLECTION=documents
MONGODB_VECTOR_INDEX=embedding_vector_cosine_1024
BUILDING_ID=gmv

# Claude generates the final answer from retrieved evidence.
ANTHROPIC_API_KEY=...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Required for true vector retrieval against the existing MongoDB embeddings.
# If omitted, the app falls back to MongoDB text search.
VOYAGE_API_KEY=...
VOYAGE_MODEL=voyage-3.5
