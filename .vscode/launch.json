    "version": "0.2.0",
    "configurations": [
        {
            "name": "GmvAgent Debug",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/GmvAgent/bin/Debug/net9.0/GmvAgent.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/GmvAgent",
            "stopAtEntry": false,
            "serverReadyAction": {
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s",
                "action": "openExternally"
            },
            "preLaunchTask": "build",
            "envFile": "${workspaceFolder}/src/GmvAgent/.env"
        }

    ]
}